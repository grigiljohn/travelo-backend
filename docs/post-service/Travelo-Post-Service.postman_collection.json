							"mode": "formdata",
							"formdata": [
								{
									"key": "files",
									"type": "file",
									"src": [],
									"description": "One or more files (images/videos)"
								},
								{
									"key": "caption",
									"value": "Beautiful sunset at the beach! 🌅",
									"type": "text",
									"description": "Post caption/description"
								},
								{
									"key": "mood",
									"value": "adventure",
									"type": "text",
									"description": "Mood type (required): chill, love, adventure, party, nature, food, culture, romantic, activity, relax"
								},
								{
									"key": "location",
									"value": "Bali, Indonesia",
									"type": "text",
									"description": "Location string (optional)"
								},
								{
									"key": "tags",
									"value": "travel,beach,sunset",
									"type": "text",
									"description": "Comma-separated tags (optional)"
								},
								{
									"key": "owner_id",
									"value": "{{owner_id}}",
									"type": "text",
									"description": "UUID of the post owner (required)"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/v1/posts",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"posts"
							]
						},
						"description": "Creates a post with file uploads. Files are uploaded directly and processed."
					},
					"response": []
				},
