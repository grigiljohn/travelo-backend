# Optional override: rename to `railway.toml` at repo root, or paste into Dashboard → Config-as-code.
# Default API-gateway deploy uses repo-root `railway.json` (Dockerfile builder); use this file only if you replace that.
# Build context must be the monorepo root (parent of services/).

[build]
builder = "DOCKERFILE"
# Repo root Dockerfile matches services/api-gateway/Dockerfile; root path matches Railway defaults.
dockerfilePath = "Dockerfile"
watchPatterns = ["services/api-gateway/**", "libs/**", "pom.xml"]

[deploy]
healthcheckPath = "/actuator/health"
healthcheckTimeout = 120
restartPolicyType = "ON_FAILURE"
