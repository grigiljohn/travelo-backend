# Railway: map from Postgres plugin (reference variables) or paste manually.
# JDBC URL must use jdbc:postgresql: scheme (not postgres://).

POSTGRES_URL=jdbc:postgresql://${PGHOST}:${PGPORT}/${PGDATABASE}
POSTGRES_USERNAME=${PGUSER}
POSTGRES_PASSWORD=${PGPASSWORD}

REDIS_HOST=${REDISHOST}
REDIS_PORT=${REDISPORT}
# REDIS_PASSWORD= if your Redis requires auth

# Optional: point to deployed config-server
# SPRING_CONFIG_IMPORT=optional:configserver:https://your-config-server.up.railway.app

JWT_SECRET=change-me-use-railway-secret-generator-min-32-chars

JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=70 -XX:InitialRAMPercentage=30
