# Must match identity-service signing secret (HS256).
JWT_SECRET=change-me-same-as-identity

# Eureka (public URL of service-registry)
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=https://your-registry.up.railway.app/eureka/

# Optional config server
# SPRING_CONFIG_IMPORT=optional:configserver:https://your-config.up.railway.app

# If NOT using Eureka lb:// resolution, set explicit HTTPS URLs for downstreams:
IDENTITY_SERVICE_URI=https://your-identity.up.railway.app
SOCIAL_SERVICE_URI=https://your-social.up.railway.app
REALTIME_SERVICE_URI=https://your-realtime.up.railway.app
DISCOVERY_SERVICE_URI=https://your-discovery.up.railway.app
MEDIA_SERVICE_URI=https://your-media.up.railway.app
COMMERCE_SERVICE_URI=https://your-commerce.up.railway.app
PLATFORM_SERVICE_URI=https://your-platform.up.railway.app

JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=70 -XX:InitialRAMPercentage=30
