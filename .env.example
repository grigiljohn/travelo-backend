# ---------------------------------------------------------------------------
# Copy to `.env` and fill in before `docker compose up -d --build`.
# `.env` is git-ignored (add it if you haven't already).
# ---------------------------------------------------------------------------

# Spring profile applied to every service container.
# `docker` is the default; switch to `production` when pointing at real AWS deps.
SPRING_PROFILES_ACTIVE=docker

# Postgres (used by every *-service that talks to a DB).
POSTGRES_USER=travelo
POSTGRES_PASSWORD=travelo

# MUST be exactly 32 bytes for HS256. Regenerate for production (e.g. `openssl rand -hex 16`).
JWT_SECRET=your-256-bit-secret-key-32-bytes!!

# ---------------- media-service / S3 ----------------
# Leave MEDIA_S3_ENABLED=false for pure-local development; blobs live on the
# `media-uploads` docker volume.
MEDIA_S3_ENABLED=false
MEDIA_S3_BUCKET=travelo-media-local
MEDIA_S3_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---------------- Optional external integrations ----------------
OPENAI_ENABLED=false
OPENAI_API_KEY=
REEL_MUSIC_OVERRIDE_URLS=

# discovery-service: live place search, /api/v1/locations, /api/v1/search/places
# Enable "Places API" on the key in Google Cloud Console; restrict by server IP in production.
GOOGLE_PLACES_API_KEY=
